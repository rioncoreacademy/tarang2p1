{
  "name": "Tarang2_dp1 — Multi-User Server",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/python:1": {"version": "3.11"}
  },
  "forwardPorts": [80, 6081, 6082, 6083, 6084, 6085],
  "portsAttributes": {
    "80":   {"label": "Tarang2_dp1 Portal",  "onAutoForward": "openBrowser", "visibility": "public"},
    "6081": {"label": "Desktop 1", "visibility": "public"},
    "6082": {"label": "Desktop 2", "visibility": "public"},
    "6083": {"label": "Desktop 3", "visibility": "public"},
    "6084": {"label": "Desktop 4", "visibility": "public"},
    "6085": {"label": "Desktop 5", "visibility": "public"}
  },
  "secrets": {
    "GH_CLIENT_ID":     {"description": "GitHub OAuth App Client ID"},
    "GH_CLIENT_SECRET": {"description": "GitHub OAuth App Client Secret"},
    "CHIPCRAFT_KEY":        {"description": "Encryption key for lab files"},
    "VNC_PASSWORD":         {"description": "VNC password for student desktops (default: novnc)"},
    "TEMPLATE_REPO":        {"description": "GitHub repo to fork per student e.g. rioncoreacademy/lab-template (optional)"}
  },
  "postCreateCommand": "cd ${containerWorkspaceFolder} && bash .devcontainer/multi-user/init.sh",
  "postStartCommand": "pip install -q fastapi==0.115.0 uvicorn==0.30.6 httpx==0.27.2 docker==7.1.0 && cd ${containerWorkspaceFolder}/api && nohup uvicorn main:app --host 0.0.0.0 --port 80 > /tmp/api.log 2>&1 &",
  "remoteUser": "root"
}
