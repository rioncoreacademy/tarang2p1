{
  "name": "ChipCraft Lab — Multi-User Server",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "forwardPorts": [80, 6081, 6082, 6083, 6084, 6085],
  "portsAttributes": {
    "80":   {"label": "ChipCraft Portal",  "onAutoForward": "openBrowser", "visibility": "public"},
    "6081": {"label": "Lab Desktop 1", "visibility": "public"},
    "6082": {"label": "Lab Desktop 2", "visibility": "public"},
    "6083": {"label": "Lab Desktop 3", "visibility": "public"},
    "6084": {"label": "Lab Desktop 4", "visibility": "public"},
    "6085": {"label": "Lab Desktop 5", "visibility": "public"}
  },
  "secrets": {
    "GH_CLIENT_ID":     {"description": "GitHub OAuth App Client ID"},
    "GH_CLIENT_SECRET": {"description": "GitHub OAuth App Client Secret"},
    "CHIPCRAFT_KEY":        {"description": "Encryption key for lab files"},
    "VNC_PASSWORD":         {"description": "VNC password for student desktops (default: novnc)"},
    "TEMPLATE_REPO":        {"description": "GitHub repo to fork per student e.g. narrave/lab-template (optional)"}
  },
  "postCreateCommand": "cd ${containerWorkspaceFolder} && bash .devcontainer/multi-user/init.sh",
  "postStartCommand": "cd ${containerWorkspaceFolder} && docker compose up -d api",
  "remoteUser": "root"
}
