GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
TEMPLATE_REPO=your-github-username/lab-template

# Encryption key for encrypted Verilog lab files (plain text, not base64)
CHIPCRAFT_KEY=your-secret-key-here

# VNC password students use to connect (optional, defaults to "novnc")
VNC_PASSWORD=your-vnc-password-here

# Port range for dynamic containers — open this range in OCI Security List
# 6081-6180 = 100 simultaneous users
PORT_START=6081
PORT_END=6180

# Session lifetime in seconds (14400 = 4 hours)
SESSION_TTL=14400

# Host path for shared read-only instructor materials
SHARED_PATH=/data/workspace/project
